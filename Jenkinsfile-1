pipeline {
    agent any

    environment {
        OUTPUT_DIR = "/data"
    }

    stages {

        stage('Run Script in Docker') {
            steps {
                script {
                    docker.image('redirect-python').inside('-v /home/ubuntu/data:/data') {
                        sh '''
                        
                           TIMESTAMP=$(date +"%Y%m%d_%H%M%S")

                           python redirect_check-1.py

                           mv redirect_results*.xlsx $OUTPUT_DIR/ || echo "No XLSX file found"

                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✅ Job completed"
        }
        failure {
            echo "❌ Job failed"
        }
    }
}
